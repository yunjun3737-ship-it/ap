local ListTab = Window:CreateTab("명단", 4483362458)
ListTab:CreateSection("플레이어 타겟 설정")

local selectedTarget = nil
local playerList = {}

local function updatePlayerList()
    playerList = {}
    for _, player in pairs(Players:GetPlayers()) do
        table.insert(playerList, player.Name)
    end
end
updatePlayerList()

Players.PlayerAdded:Connect(updatePlayerList)
Players.PlayerRemoving:Connect(updatePlayerList)

local TargetDropdown = ListTab:CreateDropdown({
    Name = "플레이어 선택",
    Options = playerList,
    CurrentOption = "",
    Flag = "TargetDropdown",
    Callback = function(Option)
        selectedTarget = Option
        Rayfield:Notify({
            Title = "타겟 설정",
            Content = selectedTarget .. " 님이 타겟으로 설정되었습니다.",
            Duration = 3,
            Image = 4483362458
        })
    end
})

ListTab:CreateButton({
    Name = "플레이어 목록 새로고침",
    Callback = function()
        updatePlayerList()
        TargetDropdown:Refresh(playerList)
        Rayfield:Notify({
            Title = "완료",
            Content = "플레이어 목록이 갱신되었습니다.",
            Duration = 2,
            Image = 4483362458
